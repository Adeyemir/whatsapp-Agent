# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# 1. Open Telegram, search @BotFather
# 2. Send /newbot, follow the steps, get your token
# 3. Paste it here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─── Google Gemini ─────────────────────────────────────────────────────────────
# Free key at: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key

# ─── Web Search (optional) ────────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=

# ─── Agent Behaviour ───────────────────────────────────────────────────────────
AGENT_NAME=Friday
MAX_HISTORY_MESSAGES=20
GEMINI_MODEL=gemini-2.0-flash

# ─── Shell Safety ─────────────────────────────────────────────────────────────
# Commands the agent can run WITHOUT asking your permission first
ALLOWED_COMMAND_PREFIXES=circle,curl -sL https://agents.circle.com,npx skills,npm install -g @circle-fin/cli
