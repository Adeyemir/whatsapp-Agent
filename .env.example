# ─── Twilio WhatsApp ───────────────────────────────────────────────────────────
# 1. Sign up at https://www.twilio.com (free)
# 2. Console → Account Info → copy Account SID & Auth Token
# 3. Go to Messaging → Try it out → Send a WhatsApp message (Sandbox)
# 4. The sandbox number is always whatsapp:+14155238886 (Twilio's shared number)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── LLM Provider Switch ────────────────────────────────────────────────────────
# Choose between: "groq", "gemini", "anthropic", or "openrouter"
LLM_PROVIDER=groq

# ─── Groq (LLM) ────────────────────────────────────────────────────────────────
# Free key at: https://console.groq.com
# llama-3.3-70b-versatile is the most reliable Groq model for tool calling.
GROQ_API_KEY=gsk_your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Google Gemini (LLM) ───────────────────────────────────────────────────────
# Get key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ─── Anthropic Claude (LLM) ───────────────────────────────────────────────────
# Get key at: https://console.anthropic.com/
# Recommended: claude-3-5-sonnet-latest
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ─── OpenRouter (Multi-model) ──────────────────────────────────────────────────
# Get key at: https://openrouter.ai/
# Access any model (e.g. openai/gpt-4o, deepseek/deepseek-r1)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini

# ─── Web Search ────────────────────────────────────────────────────────────────
# Web search is paid per call through the Circle x402 marketplace (no key needed).
# Searches at or under SEARCH_MAX_AUTO_USDC auto-pay; pricier ones ask first.
SEARCH_SERVICE_URL=https://api.aisa.one/apis/v2/tavily/search
SEARCH_MAX_AUTO_USDC=0.05
# Optional legacy Brave key (unused by default; marketplace search is the path).
BRAVE_SEARCH_API_KEY=

# ─── Agent Behaviour ───────────────────────────────────────────────────────────
AGENT_NAME=Friday
MAX_HISTORY_MESSAGES=20

# ─── Shell Safety ─────────────────────────────────────────────────────────────
# Commands the agent can run WITHOUT asking your permission first
ALLOWED_COMMAND_PREFIXES=circle,curl -sL https://agents.circle.com,npx skills,npm install -g @circle-fin/cli

# ─── Default Blockchain Chain ──────────────────────────────────────────────────
# The chain Friday checks balances and makes payments on by default.
# Mainnet: BASE, ETH, MATIC (Polygon), ARB (Arbitrum)
# Testnet: BASE-SEPOLIA, ETH-SEPOLIA, MATIC-AMOY, ARB-SEPOLIA
DEFAULT_CHAIN=BASE
